# Per-project network policy. key=value, `#` comments allowed.
#
# vpn=<name>        Route all container traffic through a wireguard config
#                   named <name> (resolved against $SBX_VPN_DIR or absolute
#                   path). Empty value disables.
#
# tailscale=1       Bring up a tailscale sidecar using the default auth key
#                   ($SBX_TAILSCALE_AUTHKEY).
# tailscale=<name>  Use the named profile's auth key
#                   ($SBX_TAILSCALE_AUTHKEY_<NAME>). Manage profiles via
#                   `sbx net tailscale auth [name]`.
vpn=mullvad-de
tailscale=work
